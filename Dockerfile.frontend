# Frontend Dockerfile for TradingAgents (Next.js)
FROM node:20-alpine

WORKDIR /app/frontend

# Install dependencies
COPY frontend/package*.json ./
RUN npm install

# Copy frontend code
COPY frontend/ .

# Build the application (for production)
# RUN npm run build

# Expose port
EXPOSE 3000

# Development mode
CMD ["npm", "run", "dev"]

# Production mode (uncomment)
# CMD ["npm", "start"]