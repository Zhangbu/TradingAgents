# ============================================
# TradingAgents 环境配置
# ============================================
# 复制此文件为 .env 并填入你的配置

# ============================================
# LLM 提供商配置
# ============================================
# 必须至少配置一个 LLM 提供商

# ----- 主要提供商 -----
# OpenAI (GPT-4, GPT-4o, o1, o3 等)
OPENAI_API_KEY=

# Google (Gemini 系列)
GOOGLE_API_KEY=

# Anthropic (Claude 系列)
ANTHROPIC_API_KEY=

# ----- OpenAI 兼容提供商 -----
# X.AI (Grok 系列)
XAI_API_KEY=

# OpenRouter (聚合多个模型)
OPENROUTER_API_KEY=

# ----- 国内 LLM 提供商 -----
# DeepSeek (deepseek-chat, deepseek-coder, deepseek-reasoner)
DEEPSEEK_API_KEY=

# Moonshot 月之暗面 (moonshot-v1-8k/32k/128k)
MOONSHOT_API_KEY=

# Zhipu 智谱 AI (GLM 系列)
ZHIPU_API_KEY=

# SiliconFlow (聚合多个开源模型)
SILICONFLOW_API_KEY=

# ----- 自定义 OpenAI 兼容 API -----
# 用于任何 OpenAI 兼容的 API 服务
# CUSTOM_API_KEY=
# BACKEND_URL=https://your-api-endpoint.com/v1

# ============================================
# LLM 设置
# ============================================
# 选择 LLM 提供商: openai, google, anthropic, xai, ollama, openrouter,
#                  deepseek, moonshot, zhipu, siliconflow, custom
LLM_PROVIDER=openai

# 模型配置 (根据提供商选择合适的模型)
# DEEP_THINK_LLM=gpt-4o        # 深度思考模型
# QUICK_THINK_LLM=gpt-4o-mini  # 快速思考模型

# 自定义 API 端点 (可选，用于覆盖默认端点)
# BACKEND_URL=https://api.openai.com/v1

# ============================================
# 金融数据 API
# ============================================
ALPHA_VANTAGE_API_KEY=

# ============================================
# 交易所 API Keys（实盘交易需要）
# ============================================

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Futu OpenD（港股/美股）
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# ============================================
# 系统配置
# ============================================

# 数据库（默认 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/tradingagents.db

# 安全（生产环境必须修改）
SECRET_KEY=your-secret-key-change-in-production
MASTER_KEY=your-master-key-for-api-encryption

# CORS 允许的域名
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 环境
ENVIRONMENT=development
DEBUG=false

# ============================================
# Agent 配置
# ============================================

# 辩论轮数
MAX_DEBATE_ROUNDS=1
MAX_RISK_DISCUSS_ROUNDS=1

# 后端 URL（用于 Ollama 本地模型）
# BACKEND_URL=http://localhost:11434